{
  "entities": {
    "Profile": {
      "title": "Player Profile",
      "description": "Stores user statistics and progress.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "highScore": { "type": "number" },
        "totalGames": { "type": "number" },
        "level": { "type": "number" },
        "experience": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName"]
    },
    "Score": {
      "title": "Leaderboard Score",
      "description": "A single game score entry for the leaderboard.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "score": { "type": "number" },
        "mode": { "type": "string", "enum": ["competitive", "practice"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "score", "mode", "timestamp"]
    }
  },
  "firestore": {
    "/profiles/{uid}": {
      "schema": "Profile",
      "description": "User profiles indexed by UID."
    },
    "/leaderboard/{scoreId}": {
      "schema": "Score",
      "description": "Global leaderboard entries."
    }
  }
}
